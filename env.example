# Copy these to your environment or paste into application.properties locally.
# Do NOT commit real keys to GitHub (push protection will block them).

PORT=8080
APP_BASE_URL=http://localhost:8080

GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_CURRENCY=pkr

SPRING_DATASOURCE_URL=jdbc:h2:file:./data/pakbzer;AUTO_SERVER=TRUE
SPRING_DATASOURCE_DRIVER=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=

H2_CONSOLE_ENABLED=true
THYMELEAF_CACHE=false

# Google redirect URI to register in Google Cloud:
#   Local:  http://localhost:8080/login/oauth2/code/google
#   Deploy: https://your-domain.com/login/oauth2/code/google
