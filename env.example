# =============================================================================
# PakBzer — environment template (copy to .env and fill in real values)
# =============================================================================
#   cp env.example .env
# Never commit .env to GitHub. See SETUP-SECRETS.md for full setup guide.
# =============================================================================

# -----------------------------------------------------------------------------
# Server
# -----------------------------------------------------------------------------
PORT=8080
APP_BASE_URL=http://localhost:8080

# -----------------------------------------------------------------------------
# Google OAuth2
# Console: https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:8080/login/oauth2/code/google
# JS origin:    http://localhost:8080
# -----------------------------------------------------------------------------
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
GOOGLE_REDIRECT_URI=http://localhost:8080/login/oauth2/code/google

# -----------------------------------------------------------------------------
# Stripe (test mode)
# Keys:    https://dashboard.stripe.com/apikeys
# Webhook: stripe listen --forward-to localhost:8080/api/webhooks/stripe
# -----------------------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key
STRIPE_CURRENCY=pkr
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret

# -----------------------------------------------------------------------------
# App URLs (CORS + optional separate frontend)
# -----------------------------------------------------------------------------
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# -----------------------------------------------------------------------------
# SendGrid (order confirmation emails — optional)
# -----------------------------------------------------------------------------
SENDGRID_API_KEY=
SENDGRID_FROM=noreply@pakbazer.pk

# -----------------------------------------------------------------------------
# Database — local H2 (default) or PostgreSQL (prod profile)
# Set SPRING_PROFILES_ACTIVE=prod to switch to PostgreSQL below.
# -----------------------------------------------------------------------------
SPRING_PROFILES_ACTIVE=

# H2 (used when SPRING_PROFILES_ACTIVE is empty)
SPRING_DATASOURCE_URL=jdbc:h2:file:./data/pakbzer;AUTO_SERVER=TRUE
SPRING_DATASOURCE_DRIVER=org.h2.Driver
SPRING_DATASOURCE_USERNAME=sa
SPRING_DATASOURCE_PASSWORD=
H2_CONSOLE_ENABLED=true

# PostgreSQL (used when SPRING_PROFILES_ACTIVE=prod)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=pakbazer
DB_USER=pakbazer
DB_PASSWORD=pakbazer

# -----------------------------------------------------------------------------
# Google Cloud Storage (product images — optional)
# Set GOOGLE_APPLICATION_CREDENTIALS=C:\path\to\service-account.json
# -----------------------------------------------------------------------------
GCP_PROJECT_ID=
GCP_STORAGE_BUCKET=

# -----------------------------------------------------------------------------
# Other
# -----------------------------------------------------------------------------
THYMELEAF_CACHE=false
JPA_HIBERNATE_DDL_AUTO=update
